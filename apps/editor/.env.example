# Required — the editor refuses all requests until both are set (see src/middleware.ts).
# This is the account/password behind the browser's HTTP Basic Auth login popup.
# Put real values in .env.local (gitignored) or your VM's process manager env, never here.
EDITOR_USERNAME=
EDITOR_PASSWORD=

# Optional override — only needed if the repo layout differs from the default
# apps/editor -> ../../data (see packages/shared/src/lib/data-paths.ts).
# DATA_DIR=
